# Public site URL used for metadata and canonical links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Search-engine ownership verification (HTML meta-tag method). Paste the token
# from Google Search Console / Bing Webmaster Tools, then redeploy. Optional —
# leave empty if verifying via DNS. See docs/search-console-setup.md.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Google Analytics 4 (gtag.js) is the site's analytics provider. Measurement ID
# like G-XXXXXXXXXX from a GA4 web data stream. Leave empty to keep GA4 off
# (locally and per environment). NOTE: GA4 sets cookies. See docs/analytics.md.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required by `npm run supabase:types` for hosted Supabase projects.
SUPABASE_PROJECT_ID=

# Server-only secret accepted as either `Authorization: Bearer ...` or HMAC-SHA256 `x-ai-signature`.
AI_DRAFT_WEBHOOK_SECRET=

# Server-only Claude drafting configuration. Set the model to Anthropic's current preferred Claude model.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
